{
  "name": "hmounir-portfolio",
  "version": "2.0.0",
  "description": "Hamza Mounir - Senior Software Engineer Portfolio",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:prod": "node scripts/build-prod.js",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "generate-og": "node scripts/generate-og-image.js",
    "prebuild": "npm run generate-og",
    "analyze": "ANALYZE=true next build",
    "clean": "rm -rf .next && rm -rf node_modules/.cache && echo 'Cache cleared successfully!'",
    "dev:clean": "npm run clean && npm run dev",
    "troubleshoot": "node scripts/troubleshoot.js"
  },
  "keywords": [
    "portfolio",
    "resume",
    "nextjs",
    "software-engineer",
    "brussels"
  ],
  "author": "Hamza Mounir",
  "license": "ISC",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "framer-motion": "^11.18.0",
    "next": "^15.3.0",
    "next-i18next": "^15.4.3",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-confetti": "^6.4.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.0",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.3.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
